#!/bin/bash
#
# Qwen Code Universal Installer
# One command for all platforms - redirects to platform-specific installer
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/joeytoday/obsidian-notes/main/qwencode-installer/install | bash
#
# This script detects your platform and runs the appropriate installer:
# - macOS/Linux: Runs install-qwen.sh
# - Windows: Runs install-qwen.bat
#

set -e

# ============================================
# Configuration
# ============================================
BASE_URL="https://qwen-code-assets.oss-cn-hangzhou.aliyuncs.com/installation"

# ============================================
# Colors
# ============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# ============================================
# Logging
# ============================================
info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
success() { echo -e "${GREEN}✅ $1${NC}"; }
error() { echo -e "${RED}❌ $1${NC}"; exit 1; }

# ============================================
# Platform Detection
# ============================================
detect_platform() {
    case "$(uname -s 2>/dev/null)" in
        Darwin*)    echo "mac" ;;
        Linux*)     echo "linux" ;;
        MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
        *)          echo "unknown" ;;
    esac
}

# ============================================
# macOS/Linux Installation
# ============================================
install_unix() {
    info "Detected macOS/Linux, running bash installer..."
    
    # Download and execute the bash installer
    bash -c "$(curl -fsSL ${BASE_URL}/install-qwen.sh)"
}

# ============================================
# Windows Installation
# ============================================
install_windows() {
    info "Detected Windows, running batch installer..."
    
    # Create temp directory
    local temp_dir
    if [[ -n "$TEMP" ]]; then
        temp_dir="$TEMP"
    elif [[ -n "$TMP" ]]; then
        temp_dir="$TMP"
    else
        temp_dir="/tmp"
    fi
    
    local batch_file="${temp_dir}/install-qwen.bat"
    
    # Download batch file
    info "Downloading Windows installer..."
    if curl -fsSL -o "$batch_file" "${BASE_URL}/install-qwen.bat"; then
        success "Downloaded Windows installer"
    else
        error "Failed to download Windows installer"
    fi
    
    # Check if we're in WSL and can call Windows batch
    if command -v cmd.exe &>/dev/null; then
        info "Executing Windows installer..."
        echo ""
        cmd.exe /c "$batch_file"
    else
        # Not in WSL, show instructions
        echo ""
        echo "  Please run the batch file manually:"
        echo "  $batch_file"
        echo ""
        echo "  Or run in CMD:"
        echo "  cmd.exe /c $batch_file"
        echo ""
    fi
}

# ============================================
# Main
# ============================================
main() {
    local platform=$(detect_platform)
    
    echo ""
    echo "=========================================="
    echo "   Qwen Code Installer"
    echo "=========================================="
    echo ""
    info "Detecting platform..."
    
    case "$platform" in
        mac|linux)
            install_unix
            ;;
        windows)
            install_windows
            ;;
        *)
            error "Unsupported platform: $platform"
            echo "Supported platforms: macOS, Linux, Windows"
            exit 1
            ;;
    esac
}

main "$@"
