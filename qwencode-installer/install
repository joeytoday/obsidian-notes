#!/bin/bash
#
# Qwen Code Universal Installer
# One command for all platforms
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/joeytoday/obsidian-notes/main/qwencode-installer/install | bash
#

set -e

BASE_URL="https://qwen-code-assets.oss-cn-hangzhou.aliyuncs.com/installation"

# Detect platform
platform=$(uname -s 2>/dev/null)

case "$platform" in
    Darwin|Linux)
        echo "ℹ️  macOS/Linux detected, running bash installer..."
        bash -c "$(curl -fsSL ${BASE_URL}/install-qwen.sh)"
        ;;
    MINGW*|MSYS*|CYGWIN*)
        echo "ℹ️  Windows detected, running batch installer..."
        # Download and execute batch file using PowerShell (more reliable on Windows)
        powershell.exe -Command "irm '${BASE_URL}/install-qwen.bat' -o '\$env:TEMP\install-qwen.bat'; & '\$env:TEMP\install-qwen.bat'"
        ;;
    *)
        echo "❌ Unsupported platform: $platform"
        exit 1
        ;;
esac
