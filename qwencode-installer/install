#!/bin/bash
#
# Qwen Code Universal Installer
# One command for all platforms
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/joeytoday/obsidian-notes/main/qwencode-installer/install | bash
#

BASE_URL="https://qwen-code-assets.oss-cn-hangzhou.aliyuncs.com/installation"

# Detect platform
case "$(uname -s 2>/dev/null)" in
    Darwin|Linux)
        echo "ℹ️  macOS/Linux detected"
        bash -c "$(curl -fsSL ${BASE_URL}/install-qwen.sh)"
        ;;
    MINGW*|MSYS*|CYGWIN*)
        echo "ℹ️  Windows detected"
        # Download and run batch file
        curl -fsSL -o "$TEMP/install-qwen.bat" "${BASE_URL}/install-qwen.bat" && "$TEMP/install-qwen.bat"
        ;;
    *)
        echo "❌ Unsupported platform: $(uname -s)"
        exit 1
        ;;
esac
