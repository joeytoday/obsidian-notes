#!/bin/bash
#
# Qwen Code Universal Installer
# 自动检测平台或让用户选择
#
# Usage:
#   curl -fsSL https://qwen.ai/install | bash
#
# 支持自动检测，也支持手动指定平台：
#   curl -fsSL https://qwen.ai/install | bash -s -- --platform mac
#   curl -fsSL https://qwen.ai/install | bash -s -- --platform windows
#   curl -fsSL https://qwen.ai/install | bash -s -- --platform linux
#

set -e

# ============================================
# 配置
# ============================================
INSTALLER_VERSION="1.0.0"
DEFAULT_NODE_VERSION="20.18.1"
DEFAULT_NPM_REGISTRY="https://registry.npmmirror.com"

# ============================================
# 颜色定义
# ============================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ============================================
# 日志函数
# ============================================
info()    { echo -e "${BLUE}ℹ️  $1${NC}"; }
success() { echo -e "${GREEN}✅ $1${NC}"; }
warn()    { echo -e "${YELLOW}⚠️  $1${NC}"; }
error()   { echo -e "${RED}❌ $1${NC}"; exit 1; }
header()  { echo -e "\n${BOLD}$1${NC}"; }

# ============================================
# 平台检测
# ============================================
detect_platform() {
    case "$(uname -s 2>/dev/null)" in
        Darwin*)
            echo "mac"
            ;;
        Linux*)
            echo "linux"
            ;;
        MINGW*|MSYS*|CYGWIN*)
            echo "windows"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

detect_arch() {
    case "$(uname -m 2>/dev/null)" in
        x86_64|amd64)   echo "x64" ;;
        arm64|aarch64)  echo "arm64" ;;
        *)              echo "unknown" ;;
    esac
}

# ============================================
# 交互式平台选择
# ============================================
select_platform() {
    local detected=$(detect_platform)
    local detected_arch=$(detect_arch)
    
    echo ""
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║                                                          ║${NC}"
    echo -e "${CYAN}║           ${BOLD}🤖 Qwen Code 安装向导${NC}                       ${CYAN}║${NC}"
    echo -e "${CYAN}║                                                          ║${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    # 显示检测结果
    if [[ "$detected" != "unknown" ]]; then
        local platform_name
        case "$detected" in
            mac)     platform_name="macOS (${detected_arch})" ;;
            linux)   platform_name="Linux (${detected_arch})" ;;
            windows) platform_name="Windows (${detected_arch})" ;;
        esac
        echo -e "  ${GREEN}✓${NC} 检测到您的系统: ${BOLD}${platform_name}${NC}"
        echo ""
    fi
    
    echo "  请选择您的操作系统:"
    echo ""
    echo -e "    ${BOLD}[1]${NC} macOS (Intel 或 Apple Silicon)"
    echo -e "    ${BOLD}[2]${NC} Windows (需要 PowerShell)"
    echo -e "    ${BOLD}[3]${NC} Linux (x64 或 ARM64)"
    echo ""
    
    # 默认选择检测到的平台
    local default_choice
    case "$detected" in
        mac)     default_choice=1 ;;
        windows) default_choice=2 ;;
        linux)   default_choice=3 ;;
        *)       default_choice=1 ;;
    esac
    
    # 使用 /dev/tty 读取用户输入（支持管道执行）
    local choice=""
    if [[ -t 0 ]]; then
        echo -n "  请输入选择 [1-3] (默认: $default_choice): "
        read -r choice </dev/tty
    else
        # 非交互模式，尝试从 stdin 读取
        read -r choice 2>/dev/null || true
    fi
    
    # 处理空输入
    [[ -z "$choice" ]] && choice=$default_choice
    
    case "$choice" in
        1|mac|macos|darwin)
            echo ""
            echo -e "  ${GREEN}→${NC} 已选择: ${BOLD}macOS${NC}"
            echo ""
            install_mac
            ;;
        2|win|windows)
            echo ""
            echo -e "  ${GREEN}→${NC} 已选择: ${BOLD}Windows${NC}"
            echo ""
            install_windows
            ;;
        3|linux)
            echo ""
            echo -e "  ${GREEN}→${NC} 已选择: ${BOLD}Linux${NC}"
            echo ""
            install_linux
            ;;
        *)
            error "无效选择: $choice"
            echo "请重新运行脚本并选择 1、2 或 3"
            exit 1
            ;;
    esac
}

# ============================================
# macOS 安装
# ============================================
install_mac() {
    info "开始安装 Qwen Code for macOS..."
    echo ""
    
    # 检查 Node.js
    if check_node; then
        success "Node.js $(node -v) 已安装"
    else
        warn "需要安装 Node.js 20+"
        install_node_unix "darwin"
    fi
    
    install_qwen_npm
}

# ============================================
# Linux 安装
# ============================================
install_linux() {
    info "开始安装 Qwen Code for Linux..."
    echo ""
    
    # 检查 Node.js
    if check_node; then
        success "Node.js $(node -v) 已安装"
    else
        warn "需要安装 Node.js 20+"
        install_node_unix "linux"
    fi
    
    install_qwen_npm
}

# ============================================
# Windows 安装 (引导)
# ============================================
install_windows() {
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "  Windows 用户请使用 PowerShell 运行以下命令:"
    echo ""
    echo -e "  ${CYAN}irm https://qwen.ai/install.ps1 | iex${NC}"
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    
    # 检查是否在 Git Bash / WSL 中运行
    if command -v powershell.exe &>/dev/null; then
        echo "  检测到您在 Windows 环境中运行此脚本"
        echo ""
        echo -n "  是否要自动打开 PowerShell 进行安装? [y/N]: "
        
        local answer
        read -r answer </dev/tty
        
        if [[ "$answer" =~ ^[Yy]$ ]]; then
            echo ""
            info "正在启动 PowerShell 安装..."
            powershell.exe -Command "irm https://qwen.ai/install.ps1 | iex"
            return
        fi
    fi
    
    echo "  或者手动下载安装:"
    echo "  1. 打开 PowerShell (以管理员身份运行)"
    echo "  2. 复制并执行上面的命令"
    echo ""
}

# ============================================
# Node.js 检查
# ============================================
check_node() {
    if command -v node &>/dev/null; then
        local version
        version=$(node -v 2>/dev/null | sed 's/v//')
        local major
        major=$(echo "$version" | cut -d. -f1 | sed 's/[^0-9]//g')
        
        if [[ -n "$major" ]] && [[ "$major" -ge 20 ]]; then
            return 0
        fi
    fi
    return 1
}

# ============================================
# Node.js 安装 (Unix)
# ============================================
install_node_unix() {
    local os="$1"
    local arch=$(detect_arch)
    local version="${QWEN_NODE_VERSION:-$DEFAULT_NODE_VERSION}"
    local install_dir="${QWEN_INSTALL_DIR:-$HOME/.qwen}/node"
    
    info "正在安装 Node.js v${version}..."
    
    # 构建下载 URL
    local archive_name="node-v${version}-${os}-${arch}"
    [[ "$os" == "linux" ]] && [[ "$arch" == "arm64" ]] && archive_name="node-v${version}-${os}-${arch}-glibc"
    
    local ext="tar.gz"
    local url="https://nodejs.org/dist/v${version}/${archive_name}.${ext}"
    
    # 下载
    local tmp_dir
    tmp_dir=$(mktemp -d)
    
    info "下载中..."
    if command -v curl &>/dev/null; then
        curl -fsSL "$url" -o "${tmp_dir}/node.${ext}" || {
            rm -rf "$tmp_dir"
            error "下载失败，请检查网络连接"
        }
    elif command -v wget &>/dev/null; then
        wget -q "$url" -O "${tmp_dir}/node.${ext}" || {
            rm -rf "$tmp_dir"
            error "下载失败，请检查网络连接"
        }
    else
        error "需要 curl 或 wget，请先安装其中之一"
    fi
    
    # 解压
    info "解压中..."
    mkdir -p "$install_dir"
    tar xzf "${tmp_dir}/node.${ext}" -C "${tmp_dir}"
    mv "${tmp_dir}/${archive_name}"/* "$install_dir/" 2>/dev/null || true
    
    rm -rf "$tmp_dir"
    
    # 设置 PATH
    export PATH="${install_dir}/bin:${PATH}"
    
    # 添加到 shell profile
    add_to_shell_profile "${install_dir}/bin"
    
    success "Node.js $(node -v) 安装完成"
}

# ============================================
# 添加到 Shell Profile
# ============================================
add_to_shell_profile() {
    local bin_dir="$1"
    local profile=""
    
    case "$(basename "${SHELL:-bash}")" in
        bash) profile="${HOME}/.bashrc" ;;
        zsh)  profile="${HOME}/.zshrc" ;;
        *)    profile="${HOME}/.profile" ;;
    esac
    
    if [[ -n "$profile" ]] && [[ -f "$profile" ]]; then
        if ! grep -q "$bin_dir" "$profile" 2>/dev/null; then
            echo "" >> "$profile"
            echo "# Added by Qwen Code installer" >> "$profile"
            echo "export PATH=\"$bin_dir:\$PATH\"" >> "$profile"
            info "已添加到 $profile"
        fi
    fi
}

# ============================================
# npm 安装 Qwen Code
# ============================================
install_qwen_npm() {
    local registry="${QWEN_NPM_REGISTRY:-$DEFAULT_NPM_REGISTRY}"
    
    echo ""
    info "正在安装 Qwen Code..."
    
    # 设置 npm prefix
    local npm_prefix
    npm_prefix=$(npm config get prefix 2>/dev/null || echo "")
    
    local need_prefix=false
    if [[ -z "$npm_prefix" ]] || [[ "$npm_prefix" == *"error"* ]]; then
        need_prefix=true
    else
        case "$npm_prefix" in
            /|/usr|/usr/local|/opt|/usr/local/npm)
                need_prefix=true
                ;;
        esac
    fi
    
    if [[ "$need_prefix" == true ]]; then
        local user_prefix="${QWEN_INSTALL_DIR:-$HOME/.qwen}/npm-global"
        mkdir -p "$user_prefix"
        npm config set prefix "$user_prefix"
        export PATH="${user_prefix}/bin:${PATH}"
        add_to_shell_profile "${user_prefix}/bin"
    fi
    
    # 安装
    if npm install -g "@qwen-code/qwen-code@latest" --registry "$registry"; then
        echo ""
        success "Qwen Code 安装成功！"
        
        if command -v qwen &>/dev/null; then
            local qwen_version
            qwen_version=$(qwen --version 2>/dev/null || echo "unknown")
            success "版本: $qwen_version"
        fi
    else
        error "安装失败，请检查网络连接后重试"
    fi
}

# ============================================
# 显示帮助
# ============================================
show_help() {
    cat << 'EOF'
Qwen Code Universal Installer

用法:
  curl -fsSL https://qwen.ai/install | bash

选项:
  -p, --platform <name>   指定平台 (mac, windows, linux)
  -h, --help              显示帮助信息
  -v, --version           显示版本号
  --skip-node             跳过 Node.js 安装

环境变量:
  QWEN_INSTALL_DIR    自定义安装目录 (默认: ~/.qwen)
  QWEN_NODE_VERSION   Node.js 版本 (默认: 20.18.1)
  QWEN_NPM_REGISTRY   npm 镜像源 (默认: https://registry.npmmirror.com)

示例:
  # 交互式安装
  curl -fsSL https://qwen.ai/install | bash

  # 指定平台
  curl -fsSL https://qwen.ai/install | bash -s -- --platform mac

  # 跳过 Node.js 安装
  curl -fsSL https://qwen.ai/install | bash -s -- --skip-node

支持的平台:
  - macOS (Intel x64, Apple Silicon arm64)
  - Linux (x64, arm64)
  - Windows (通过 PowerShell)

更多信息: https://github.com/QwenLM/qwen-code
EOF
    exit 0
}

# ============================================
# 主函数
# ============================================
main() {
    local platform=""
    local skip_node=false
    
    # 解析参数
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--platform)
                platform="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                ;;
            -v|--version)
                echo "Qwen Code Installer v${INSTALLER_VERSION}"
                exit 0
                ;;
            --skip-node)
                skip_node=true
                shift
                ;;
            *)
                warn "未知选项: $1"
                shift
                ;;
        esac
    done
    
    # 导出 skip_node 供其他函数使用
    export QWEN_SKIP_NODE="$skip_node"
    
    # 根据参数或交互选择平台
    case "$platform" in
        mac|macos|darwin)
            install_mac
            ;;
        win|windows)
            install_windows
            ;;
        linux)
            install_linux
            ;;
        "")
            # 无指定平台，进入交互模式
            select_platform
            ;;
        *)
            error "未知平台: $platform"
            echo "支持的平台: mac, windows, linux"
            exit 1
            ;;
    esac
    
    # 完成提示
    echo ""
    echo -e "${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${GREEN}║                                                          ║${NC}"
    echo -e "${GREEN}║           ${BOLD}✅ 安装完成！${NC}                                  ${GREEN}║${NC}"
    echo -e "${GREEN}║                                                          ║${NC}"
    echo -e "${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  现在您可以运行:"
    echo ""
    echo -e "    ${CYAN}qwen${NC}"
    echo ""
    echo "  如果 'qwen' 命令不可用，请重启终端或运行:"
    echo "    source ~/.bashrc  # 或 ~/.zshrc"
    echo ""
}

# 运行
main "$@"